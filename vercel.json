{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/morning-drive-cron", "schedule": "30 8 * * *" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "routes": [
    { "src": "/Disney", "status": 308, "headers": { "Location": "/Hollywood%20Studios" } },
    { "src": "/Disney/(.*)", "status": 308, "headers": { "Location": "/Hollywood%20Studios/$1" } },
    { "src": "/pac-man", "status": 308, "headers": { "Location": "/chomp-chase" } },
    { "src": "/pac-man/(.*)", "status": 308, "headers": { "Location": "/chomp-chase/$1" } },
    { "src": "/space-invaders", "status": 308, "headers": { "Location": "/alien-descent" } },
    { "src": "/space-invaders/(.*)", "status": 308, "headers": { "Location": "/alien-descent/$1" } },
    { "src": "/blog/how-to-play-space-invaders", "status": 308, "headers": { "Location": "/blog/how-to-play-alien-descent" } },
    { "src": "/blog/how-to-play-space-invaders.html", "status": 308, "headers": { "Location": "/blog/how-to-play-alien-descent" } },
    { "src": "/pong", "status": 308, "headers": { "Location": "/paddle-duel" } },
    { "src": "/pong/(.*)", "status": 308, "headers": { "Location": "/paddle-duel/$1" } },
    { "src": "/Granddad's Attic", "status": 308, "headers": { "Location": "/granddads-attic" } },
    { "src": "/Granddad's Attic/(.*)", "status": 308, "headers": { "Location": "/granddads-attic/$1" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}

{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/pac-man", "destination": "/chomp-chase", "permanent": true },
    { "source": "/pac-man/(.*)", "destination": "/chomp-chase/$1", "permanent": true },
    { "source": "/space-invaders", "destination": "/alien-descent", "permanent": true },
    { "source": "/space-invaders/(.*)", "destination": "/alien-descent/$1", "permanent": true },
    { "source": "/blog/how-to-play-space-invaders", "destination": "/blog/how-to-play-alien-descent", "permanent": true },
    { "source": "/blog/how-to-play-space-invaders.html", "destination": "/blog/how-to-play-alien-descent", "permanent": true },
    { "source": "/pong", "destination": "/paddle-duel", "permanent": true },
    { "source": "/pong/(.*)", "destination": "/paddle-duel/$1", "permanent": true }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
